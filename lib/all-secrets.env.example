# 1Password integration (optional). Copy this file to `all-secrets.env` and point
# each var at your own 1Password secret reference. The run scripts auto-detect
# `all-secrets.env` + the `op` CLI and wrap generation in a single `op run`
# (one Touch ID for the whole batch). If this file is absent, the scripts fall
# back to reading the same variables straight from your shell environment
# (see `.env.example`).
#
# Format: <ENV_VAR>=op://<VAULT>/<ITEM>/<field>
RECRAFT_API_KEY=op://YourVault/Recraft/credential
GEMINI_API_KEY=op://YourVault/Gemini/credential
OPENAI_API_KEY=op://YourVault/OpenAI/credential
REPLICATE_API_TOKEN=op://YourVault/Replicate/credential
UNSPLASH_ACCESS_KEY=op://YourVault/Unsplash/credential
PEXELS_API_KEY=op://YourVault/Pexels/credential
PIXABAY_API_KEY=op://YourVault/Pixabay/credential
CLOUDINARY_CLOUD_NAME=op://YourVault/Cloudinary/cloud_name
CLOUDINARY_API_KEY=op://YourVault/Cloudinary/api_key
CLOUDINARY_API_SECRET=op://YourVault/Cloudinary/api_secret
