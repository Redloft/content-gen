# Plain env-var setup (Option A). Copy to `.env`, fill in your keys, and
# `set -a; source .env; set +a` before running — or just export these in your shell.
# Only set the ones for the providers/tiers you use.

# AI image generation
RECRAFT_API_KEY=            # https://www.recraft.ai/  (Recraft v3 — mockup scenes, branded style)
GEMINI_API_KEY=             # https://aistudio.google.com/apikey  (Gemini Nano Banana / Imagen 4)
OPENAI_API_KEY=             # https://platform.openai.com/api-keys  (gpt-image-1)
REPLICATE_API_TOKEN=        # https://replicate.com/account/api-tokens  (Flux)

# Stock photos
UNSPLASH_ACCESS_KEY=        # https://unsplash.com/developers
PEXELS_API_KEY=             # https://www.pexels.com/api/
PIXABAY_API_KEY=            # https://pixabay.com/api/docs/

# Cloudinary upload (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=      # https://cloudinary.com/console
